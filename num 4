/*Escreva um programa em C que leia uma quantidade desconhecida de números positivos e conte
quantos deles estão nos seguintes intervalos: [0, 25], [26, 50], [51, 75] e [76, 100]. A entrada de
dados deve terminar quando for lido um número negativo.*/

#include <stdio.h>
void main () {
    int num;
    int faixa[4] = {0};

    printf("Digite numeros positivos (negativo para encerrar):\n");

    do {
        printf("Numero: ");
        scanf("%d", &num);

        if      (num >= 0  && num <= 25)  faixa[0]++;
        else if (num >= 26 && num <= 50)  faixa[1]++;
        else if (num >= 51 && num <= 75)  faixa[2]++;
        else if (num >= 76 && num <= 100) faixa[3]++;

    }while (num >= 0);

    printf("\n--- Contagem por Intervalo ---\n");
    printf("[ 0 -  25]: %d numero(s)\n", faixa[0]);
    printf("[26 -  50]: %d numero(s)\n", faixa[1]);
    printf("[51 -  75]: %d numero(s)\n", faixa[2]);
    printf("[76 - 100]: %d numero(s)\n", faixa[3]);

}
