/*Faça um programa em C que leia e valide as seguintes informações de um usuário utilizando laços
de repetição:
• Idade: deve ser entre 0 e 150 anos;
• Salário: deve ser maior que zero;
• Sexo: deve ser 'M' ou 'F'.
O programa deve continuar pedindo o dado específico até que o usuário digite um valor
válido para cada um deles.*/

#include <stdio.h>
void main() {
    int idade;
    float salario;
    char sexo;

    do {
        printf("Digite a sua idade: ");
        scanf("%d", &idade);
            if (idade < 0 || idade > 150)
                printf("idade invalida\n tente novamente\n");
    }
    while (idade <= 0 || idade >= 150);

    do {
        printf("Digite o seu salario: ");
        scanf("%f", &salario);
            if (salario <= 0)
                printf("salario invalido\n tente novamente\n");
    }while (salario <= 0);

        do {
            printf("Digite o seu sexo (M/F): ");
            scanf("%c", &sexo);
                if (sexo != 'F' && sexo != 'M')
                    printf("sexo invalido\n tente novamente\n");
        }while (sexo != 'F' && sexo != 'M');

    printf ("Seus dados são: %d, %.2f, %c", idade, salario, sexo);

}
