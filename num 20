/*Escreva um programa em C que leia do usuário o primeiro termo (a1) a razão (r) e a quantidade de
termos (n) de uma progressão geométrica. O programa deve mostrar os n termos dessa progressão.*/

#include <stdio.h>
void main() {
    float a1, r, termo;
    int n;

    printf("Primeiro termo (a1): "); scanf("%f", &a1);
    printf("Razão (r): ");           scanf("%f", &r);
    printf("Quantidade de termos: "); scanf("%d",  &n);

    printf("\nTermos da PG: ");
    termo = a1;
    for (int i = 0; i < n; i++) {
        printf("%.4g", termo);
        if (i < n - 1) printf(", ");
        termo *= r;
    }
    printf("\n");
}
