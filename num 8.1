/*Escreva uma função em C que receba como argumento um
 *número inteiro qualquer e retorne 1 caso esse número seja
 *um número primo e 0 caso contrário.*/
 
#include <stdio.h>
int ePrimo(int n) {
    if (n < 2) return 0;
    for (int i = 2; i * i <= n; i++)
        if (n % i == 0) return 0;
    return 1;
}

void main(){
int n;
    printf("Digite um número: ");
    scanf("%d", &n);
    printf("Retorno da função ehPrimo(%d): %d\n", n, ePrimo(n));
}
